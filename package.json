{
  "name": "niuvis",
  "version": "1.0.0",
  "type": "module",
  "description": "Niuvis",
  "main": "main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json && node scripts/copy-main-assets.mjs",
    "dev": "npm run build:main && concurrently -k -n vite,main,electron -c blue,green,magenta \"vite\" \"tsc -p tsconfig.main.json -w\" \"wait-on http://127.0.0.1:5173 && NODE_ENV=development electron .\"",
    "build": "npm run build:main && vite build",
    "preview": "vite preview",
    "start": "npm run build:main && electron .",
    "test": "npm run build:main && npm rebuild better-sqlite3 && node --test src/main/**/*.test.js && electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyf-yfw/Niuvis.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wyf-yfw/Niuvis/issues"
  },
  "homepage": "https://github.com/wyf-yfw/Niuvis#readme",
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.7.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "better-sqlite3": "^12.10.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
